# ── Finny server configuration ─────────────────────────────────────────────
# Copy to .env and fill in what you have. Everything has a mock default:
# with an empty .env the whole app runs locally with simulated providers.

# Port for the API server (web dev server proxies /api here)
PORT=4787

# Where SQLite DB, attachments, inbox drop-folder and Sage exports live
DATA_DIR=./data

# Public URL of the web app — used in alert links
APP_URL=http://localhost:5173

# ── Mail ingestion ──────────────────────────────────────────────────────────
# mock  = watch $DATA_DIR/inbox for dropped PDF/PNG/JPG files + UI simulator
# graph = poll the shared mailbox via Microsoft Graph (fill in the GRAPH_ vars)
MAIL_PROVIDER=mock
MAIL_POLL_SECONDS=60
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX=apadmin@example.com
# Mark processed mail as read in the mailbox (true/false).
# true needs the Mail.ReadWrite application permission; with only Mail.Read
# set this to false (ingestion still works, messages just stay unread).
GRAPH_MARK_READ=true
# Days of EXISTING mailbox history to ingest on the very first poll.
# 0 (default) = only mail that arrives after Finny is switched on — the team
# has already processed the old mail by hand. Set e.g. 7 to backfill a week.
GRAPH_BACKFILL_DAYS=0

# ── Extraction ──────────────────────────────────────────────────────────────
# anthropic = Claude document extraction (needs an API key)
# mock      = deterministic text-parse extractor, works offline
# Leave EXTRACTION_PROVIDER empty to auto-select: anthropic once a key is present
# (env OR set in Settings → AI extraction), else mock. Set it to "mock" to force
# the offline parser even with a key.
EXTRACTION_PROVIDER=
# The key and model can also be set in-app (Settings → AI extraction, AP Lead) —
# the stored values win. These env vars are the deployment defaults.
ANTHROPIC_API_KEY=
EXTRACTION_MODEL=claude-opus-4-8

# ── Teams Approvals ─────────────────────────────────────────────────────────
# mock  = approval requests recorded locally + simulator panel in the UI
# graph = create Teams Approvals via Microsoft Graph (beta endpoint; uses GRAPH_ vars)
APPROVALS_PROVIDER=mock
APPROVALS_POLL_SECONDS=60

# ── Alerts (Microsoft Teams webhook) ─────────────────────────────────────────
# Failure alerts POST as an Adaptive Card to a Teams-subscribable Incoming
# Webhook. In Teams: Workflows → "Post to a channel when a webhook request is
# received", pick the channel, paste the generated URL here (or set it per
# deployment in Settings, which wins). Empty = alerts are stored + shown in-app.
ALERT_WEBHOOK_URL=

# ── Sage 50 output ───────────────────────────────────────────────────────────
# csv           = generate batch files the AP team imports by hand (default)
# hyperaccounts = one-touch "Send to Sage": batches post straight into Sage 50
#                 via the on-prem HyperAccounts REST API (Hyperext).
SAGE_PROVIDER=csv
# Default HyperAccounts server (used for every entity unless overridden below).
SAGE_API_URL=
SAGE_API_KEY=
# Header that carries the API key (confirm with Hyperext; x-api-key is typical).
SAGE_API_KEY_HEADER=x-api-key
# Each legal entity is its own Sage company dataset, usually its own server.
# JSON map of entity name -> server, e.g.
# SAGE_ENTITY_SERVERS={"Meadowvale Developments Ltd":{"url":"http://sage-dev:5891","key":"..."}}
SAGE_ENTITY_SERVERS=

# ── BlockDocs integration ────────────────────────────────────────────────────
# Bearer token BlockDocs uses to pull approved invoices for its cost dashboard.
# Leave empty to disable the endpoint (returns 503).
FINNY_BLOCKDOCS_TOKEN=

# ── Auth ────────────────────────────────────────────────────────────────────
# dev   = local name/email/role sign-in (no external dependency)
# entra = Entra ID SSO — everyone signs in with their M365 work account
AUTH_PROVIDER=dev
SESSION_SECRET=

# Entra ID SSO (AUTH_PROVIDER=entra). ENTRA_* fall back to the GRAPH_* vars,
# so the mailbox app registration can double as the sign-in app: add a Web
# redirect URI  https://<your-domain>/api/auth/entra/callback  and the
# delegated permissions openid, profile, email. See README.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# Only needed if the callback URL differs from APP_URL + /api/auth/entra/callback
ENTRA_REDIRECT_URI=

# Comma-separated emails pinned to the AP Lead role (rule approvals, settings,
# shadow/live switch). These cannot be demoted in the Settings → Team card, so
# put your own address here to guarantee access. Everyone else starts as an AP
# Processor — except, on a fresh deploy with no pins, the first person to sign
# in is promoted automatically so there is always an admin. Beyond these pins,
# privilege levels are managed in-app (Settings → Team & privileges).
FINNY_LEAD_EMAILS=

# Team directory / privilege management. Leave TEAM_PROVIDER blank to auto-pick:
# 'graph' under Entra sign-in (AUTH_PROVIDER=entra), else the 'mock' sample team
# for local dev — so a real deployment never seeds sample people, even before a
# group id is set. Governs BOTH syncs below; each still needs its own group id
# to actually pull, plus the app permission GroupMember.Read.All (admin consent).
TEAM_PROVIDER=
# Object id of the M365 group the SSO is scoped to — Settings → Team → "Sync"
# lists its members (who can sign in, and at what privilege level).
FINNY_TEAM_GROUP_ID=
# Object id of the M365 group of approving managers — Settings → Approving
# managers → "Sync" pulls its members and their Teams user ids. Can be the same
# group as above, or a separate approvers group.
FINNY_APPROVERS_GROUP_ID=
